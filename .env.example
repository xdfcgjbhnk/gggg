# ============================================================
# Gaming Rewards Platform — Environment Variables
# Set these in Railway → your service → Variables tab
# ============================================================

# Required: Node environment (must be "production" on Railway)
NODE_ENV=production

# Required: Port (Railway sets this automatically — no need to set manually)
# PORT=3000

# Required: Your Supabase/PostgreSQL connection string
DATABASE_URL=postgresql://postgres.XXXX:YOUR_PASSWORD@aws-1-XX.pooler.supabase.com:6543/postgres

# Required: Secret key for signing JWT tokens (use a long random string, min 32 chars)
SESSION_SECRET=change-this-to-a-very-long-random-secret-string-at-least-32-chars

# Optional: The email address that will automatically become super admin
# When a user registers with this exact email, they get super_admin role automatically
ADMIN_EMAIL=admin@yourdomain.com

# Optional: Log level (debug | info | warn | error)
LOG_LEVEL=info
